# ──────────────────────────────────────────────────────────────────
# Dataset Quality Scorer — environment variables
# Copy this file to .env and fill in your keys.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────

# ── LLM Review backend (pick one or both) ─────────────────────────

# OpenRouter — no extra packages needed, works out of the box.
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Anthropic direct — requires: pip install anthropic
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── HuggingFace (optional) ────────────────────────────────────────
# Needed only for private/gated datasets or to raise rate limits.
# Get a token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_...
